    {
      "parameters": {
        "jsCode": "const temp = Math.round($input.item.json.main.temp);\nconst city = $input.item.json.name;\n\n// Obtém o código do ícone da API da Open Weather\nconst iconCode = $input.first().json.weather[0].icon;\nlet emoji = '🌤'; // padrão\n\n// Dicionário de Correlação dos Ícones Climáticos\nconst iconMap = {\n  '01d': '☀️', '01n': '🌑', \n  '02d': '🌤', '02n': '☁️',\n  '03d': '☁️', '03n': '☁️',\n  '04d': '☁️', '04n': '☁️',\n  '09d': '🌧', '09n': '🌧',\n  '10d': '🌦', '10n': '🌧',\n  '11d': '⛈', '11n': '⛈',\n  '13d': '❄️', '13n': '❄️',\n  '50d': '🌫', '50n': '🌫'\n};\n\nif (iconMap[iconCode]) {\n  emoji = iconMap[iconCode];\n}\n\nconst message = `${emoji} A temperatura em ${city} é de ${temp}°C.`;\n\nreturn { \n  message: message, \n  condition: $input.first().json.weather[0].description,\n  ok: true\n};\n"
      },
