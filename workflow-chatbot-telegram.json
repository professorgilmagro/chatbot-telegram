    {
      "parameters": {
        "jsCode": "const temp = Math.round($input.item.json.main.temp);\nconst city = $input.item.json.name;\n\n// Obt\u00e9m o c\u00f3digo do \u00edcone da API da Open Weather\nconst iconCode = $input.first().json.weather[0].icon;\nlet emoji = '\ud83c\udf24'; // padr\u00e3o\n\n// Dicion\u00e1rio de Correla\u00e7\u00e3o dos \u00cdcones Clim\u00e1ticos\nconst iconMap = {\n  '01d': '\u2600\ufe0f', '01n': '\ud83c\udf11', \n  '02d': '\ud83c\udf24', '02n': '\u2601\ufe0f',\n  '03d': '\u2601\ufe0f', '03n': '\u2601\ufe0f',\n  '04d': '\u2601\ufe0f', '04n': '\u2601\ufe0f',\n  '09d': '\ud83c\udf27', '09n': '\ud83c\udf27',\n  '10d': '\ud83c\udf26', '10n': '\ud83c\udf27',\n  '11d': '\u26c8', '11n': '\u26c8',\n  '13d': '\u2744\ufe0f', '13n': '\u2744\ufe0f',\n  '50d': '\ud83c\udf2b', '50n': '\ud83c\udf2b'\n};\n\nif (iconMap[iconCode]) {\n  emoji = iconMap[iconCode];\n}\n\nconst message = `${emoji} A temperatura em ${city} \u00e9 de ${temp}\u00b0C.`;\n\nreturn { \n  message: message, \n  condition: $input.first().json.weather[0].description,\n  ok: true\n};\n"
      },
